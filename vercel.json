{
    "version": 2,
    "builds": [
      {
        "src": "core/wsgi.py",
        "use": "@vercel/python",
        "config": { "maxLambdaSize": "15mb", "runtime": "python3.10"}
      },
      {
        "src": "build_files.sh",
        "use": "@vercel/static"
      },
      {
        "src": "theme/static_src/**/*",
        "use": "@vercel/static-build",
        "config": {
          "distDir": "theme/static"
        }
      }
    ],
    "routes": [
      {
        "src": "/static/(.*)",
        "dest": "/static/$1"
      },
      {
        "src": "/(.*)",
        "dest": "core/wsgi.py"
      }
    ]
}